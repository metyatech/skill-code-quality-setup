{
  "name": "@metyatech/skill-code-quality-setup",
  "version": "1.0.0",
  "description": "Agent skill for setting up code quality tools",
  "type": "module",
  "main": "SKILL.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metyatech/skill-code-quality-setup.git"
  },
  "keywords": [
    "agent",
    "skill",
    "code-quality",
    "lint",
    "format"
  ],
  "author": "metyatech",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.47.0",
    "prettier": "^3.5.2"
  },
  "overrides": {
    "glob": ">=10.6.0",
    "minimatch": ">=10.2.4"
  },
  "scripts": {
    "format": "prettier --write \"**/*.{md,json}\"",
    "format:check": "prettier --check \"**/*.{md,json}\"",
    "lint": "markdownlint **/*.md",
    "verify": "npm run format:check && npm run lint && npm audit",
    "prepare": "husky"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  }
}
